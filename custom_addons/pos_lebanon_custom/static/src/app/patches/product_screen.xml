<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos_lebanon_custom.ProductScreen" t-inherit="point_of_sale.ProductScreen" t-inherit-mode="extension">
        <!-- Mark wrapper so our CSS scopes cleanly -->
        <xpath expr="//div[hasclass('product-screen')]" position="attributes">
            <attribute name="class" add="lebanon-product-screen" separator=" "/>
        </xpath>

        <!-- Left pane: make it a fixed flex-column that never overflows vertically -->
        <xpath expr="//div[hasclass('leftpane')]" position="attributes">
            <attribute name="class" add="lebanon-leftpane" separator=" "/>
        </xpath>

        <!-- Remove the default horizontal control-buttons row (moved to sidebar) -->
        <xpath expr="//div[hasclass('leftpane')]//div[hasclass('control-buttons')]" position="replace">
            <div class="d-none" aria-hidden="true"/>
        </xpath>

        <!-- Always show numpad when order has items + a line selected OR just items (for reliable visibility) -->
        <xpath expr="//Numpad" position="attributes">
            <attribute name="t-if">!currentOrder?.isEmpty()</attribute>
        </xpath>

        <!-- Desktop: remove CategorySelector from rightpane top (moved to sidebar) -->
        <xpath expr="//div[hasclass('rightpane')]//CategorySelector" position="replace">
            <CategorySelector t-if="ui.isSmall and !pos.scanning" />
        </xpath>

        <!-- Rightpane: ensure flex-grow works in flex row with sidebar -->
        <xpath expr="//div[hasclass('rightpane')]" position="attributes">
            <attribute name="class" add="min-w-0 flex-grow-1" separator=" "/>
        </xpath>

        <!-- Desktop sidebar: Categories + quick-action buttons -->
        <xpath expr="//div[hasclass('rightpane')]" position="after">
            <div t-if="!ui.isSmall" class="lebanon-pos-right-sidebar flex-shrink-0 d-flex flex-column">
                <!-- Category selector fills available space -->
                <div class="lebanon-sidebar-categories flex-grow-1 overflow-y-auto">
                    <CategorySelector/>
                </div>

                <!-- Action shortcuts section -->
                <div class="lebanon-sidebar-actions border-top">
                    <div class="lebanon-sidebar-actions-label px-3 pt-2 pb-1 text-uppercase text-muted small fw-semibold">Actions</div>
                    <div class="d-flex flex-column gap-1 px-2 pb-2">
                        <button class="btn btn-sm btn-outline-secondary text-start"
                            t-on-click="displayAllControlPopup">
                            <i class="fa fa-fw fa-ellipsis-h me-1"/>More Options
                        </button>
                        <button class="btn btn-sm btn-outline-danger text-start"
                            t-if="!currentOrder?.isEmpty()"
                            t-on-click="() => pos.onDeleteOrder(pos.getOrder())">
                            <i class="fa fa-fw fa-trash me-1"/>Cancel Order
                        </button>
                    </div>
                </div>

                <!-- Rate bar in sidebar footer -->
                <div class="lebanon-rate-bar-sidebar px-3 py-2 border-top text-center">
                    <span class="small text-muted">1 USD = </span>
                    <span class="small fw-bold text-primary" t-esc="formatLebanonRate()"/>
                    <span class="small text-muted"> L.L.</span>
                </div>
            </div>
        </xpath>

        <!-- Bottom rate bar (mobile / full-width footer) -->
        <xpath expr="//div[hasclass('product-screen')]" position="inside">
            <div t-if="ui.isSmall" class="lebanon-rate-bar w-100 py-1 px-3 text-center order-last" style="flex-basis: 100%;">
                <span class="fw-semibold small text-body">1 USD = </span>
                <span class="fw-bold small text-primary" t-esc="formatLebanonRate()"/>
                <span class="fw-semibold small text-body"> L.L.</span>
            </div>
        </xpath>
    </t>
</templates>
