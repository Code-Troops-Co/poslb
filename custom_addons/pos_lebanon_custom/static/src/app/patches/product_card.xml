<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos_lebanon_custom.ProductCard" t-inherit="point_of_sale.ProductCard" t-inherit-mode="extension">
        <!--
            Add LBP price as a small text under the product name.
            The product-name div already renders the name via t-esc.
            We insert the LBP line right after it (still inside product-content).
            No layout class changes — keep Odoo's original flex intact.
        -->
        <xpath expr="//div[hasclass('product-content')]//div[hasclass('product-name')]" position="after">
            <span
                t-if="!props.isComboPopup and dualProductListPrice"
                class="lebanon-product-card-price d-block w-100"
                t-out="dualProductListPrice"
            />
        </xpath>
    </t>
</templates>
