<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="pos_config_view_form_lebanon" model="ir.ui.view">
        <field name="name">pos.config.form.lebanon</field>
        <field name="model">pos.config</field>
        <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@groups='base.group_system']" position="before">
                <div class="row mt16 o_settings_container">
                    <setting
                        string="Lebanon dual currency"
                        help="LBP per one US dollar, used for POS display and Cash LBP (configure payment methods separately)."
                    >
                        <field name="lebanon_lbp_per_usd"/>
                    </setting>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
