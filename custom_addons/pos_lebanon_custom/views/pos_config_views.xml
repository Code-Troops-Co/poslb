<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="pos_config_view_form_lebanon" model="ir.ui.view">
        <field name="name">pos.config.form.lebanon</field>
        <field name="model">pos.config</field>
        <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
        <field name="arch" type="xml">
            <!-- Stable anchor: title block always exists on PoS config form -->
            <xpath expr="//div[@id='title']" position="after">
                <group string="Lebanon dual currency" colspan="2">
                    <field
                        name="lebanon_lbp_per_usd"
                        string="LBP per 1 USD"
                        help="LBP per one US dollar for POS display and Cash LBP (configure payment methods separately)."
                    />
                </group>
            </xpath>
        </field>
    </record>
</odoo>
