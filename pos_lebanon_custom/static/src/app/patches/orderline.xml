<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos_lebanon_custom.Orderline" t-inherit="point_of_sale.Orderline" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('product-price')]" position="replace">
            <div
                t-if="vals.price"
                t-out="dualLinePrice"
                class="product-price price lebanon-dual-price"
                t-attf-class="{{ vals.isReceipt ? 'font-monospace' : 'fw-bolder' }}"
            />
        </xpath>
        <xpath expr="//li[@t-out='vals.displayPriceUnit']" position="attributes">
            <attribute name="t-out">dualDisplayPriceUnit</attribute>
        </xpath>
        <xpath expr="//li[@t-if='vals.discount']/t[@t-esc='vals.noDiscountPrice']" position="replace">
            <t t-out="dualNoDiscountPrice"/>
        </xpath>
    </t>
</templates>
